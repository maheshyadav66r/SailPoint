<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE TaskDefinition PUBLIC "sailpoint.dtd" "sailpoint.dtd">
<TaskDefinition executor="com.acme.training.task.SearchTaskExecutor" name="Search Objects - Training" subType="task_item_type_system" type="System">
  <Attributes>
    <Map>
      <entry key="TaskDefinition.runLengthAverage" value="0"/>
      <entry key="TaskDefinition.runLengthTotal" value="0"/>
      <entry key="TaskDefinition.runs" value="0"/>
      <entry key="pluginName" value="TrainingPlugin"/>
    </Map>
  </Attributes>
  <Description>Search for instances of a specified string inside objects of a specified type.</Description>
  <Signature>
    <Inputs>
      <Argument name="object_type" type="string">
         <Prompt>Object Type to Search</Prompt>
      </Argument>
      <Argument name="search_term" type="string">
         <Prompt>Search Term</Prompt>
      </Argument>
    </Inputs>
    <Returns>
      <Argument name="success" type="boolean">
         <Prompt>Success: </Prompt>
      </Argument>
      <Argument name="messages" type="string">
         <Prompt>Messages: </Prompt>
      </Argument>
      <Argument name="items" type="string">
        <Prompt>Objects matching search term</Prompt>
      </Argument>
    </Returns>
  </Signature>
</TaskDefinition>

