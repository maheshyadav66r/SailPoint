<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE sailpoint PUBLIC "sailpoint.dtd" "sailpoint.dtd">
<sailpoint>
	<Configuration name="Impersonate Plugin Configuration">
		<Attributes>
			<Map>
				<entry key="authenticationRequired" value="true" />
				<entry key="userTokenRequired" value="false" />
				<entry key="impersonatorPluginFilterRule" value="Impersonator Plugin Filter Rule" />
				<entry key="impersonatorPluginRequirePasswordRule" value="Impersonator Plugin Require Password Rule" />
				<entry key="impersonatorPluginRequireTokenRule" value="Impersonator Plugin Require Token Rule" />
			</Map>
		</Attributes>
	</Configuration>

	<ImportAction name="merge">
		<Configuration name="SystemConfiguration">
			<Attributes>
				<Map>
					<entry key="quickLinkCategories">
						<value>
							<List>
								<QuickLinkCategory cssClass="quickLinkCategoryImpersonate" enabled="true" messageKey="Impersonation" name="ImpersonatePlugin" />
							</List>
						</value>
					</entry>
				</Map>
			</Attributes>
		</Configuration>
	</ImportAction>

</sailpoint>