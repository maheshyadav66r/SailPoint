<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE sailpoint PUBLIC "sailpoint.dtd" "sailpoint.dtd">
<sailpoint>
    <SPRight displayName="ImpersonatePluginRestServiceAllow" name="ImpersonatePluginRestServiceAllow">
        <Description>Allow access to Impersonate Plugin REST Service</Description>
    </SPRight>

    <Capability displayName="Impersonate Plugin Rest Service Access" name="ImpersonatePluginRestServiceAccess">
        <Description>Allow access to Impersonate Plugin REST Service</Description>
        <RightRefs>
            <Reference class="sailpoint.object.SPRight" name="ImpersonatePluginRestServiceAllow"/>
        </RightRefs>
    </Capability>

    <SPRight displayName="ImpersonatePluginRight" name="ImpersonatePluginRight">
        <Description>Access to use the Impersonate Plugin</Description>
    </SPRight>

    <SPRight displayName="Impersonate Plugin Icon Right" name="ImpersonatePluginIconRight">
        <Description>Access to see (load) the Impersonate Plugin header inject snippet</Description>
    </SPRight>

    <Capability displayName="Impersonate Plugin Capability" name="ImpersonatePluginCapability">
        <Description>Allow access to Impersonate Plugin</Description>
        <RightRefs>
            <Reference class="sailpoint.object.SPRight" name="ImpersonatePluginRight"/>
            <Reference class="sailpoint.object.SPRight" name="ImpersonatePluginIconRight"/>
            <Reference class="sailpoint.object.SPRight" name="ImpersonatePluginRestServiceAllow"/>
        </RightRefs>
    </Capability>

    <SPRight displayName="Impersonate Plugin Reporting" name="ImpersonatePluginReportRight">
        <Description>Access to see impersonation report</Description>
    </SPRight>

    <Capability displayName="Impersonate Plugin Reporting Capability" name="ImpersonatePluginReportCapability">
        <Description>Allow access to Impersonate Report</Description>
        <RightRefs>
            <Reference class="sailpoint.object.SPRight" name="ImpersonatePluginReportRight"/>
        </RightRefs>
    </Capability>

    <SPRight displayName="Impersonate Plugin Configuration" name="ImpersonatePluginConfigurationRight">
        <Description>Access to see configuration</Description>
    </SPRight>

    <Capability displayName="Impersonate Plugin Configuration Capability" name="ImpersonatePluginConfigurationCapability">
        <Description>Allow access to Impersonate Report</Description>
        <RightRefs>
            <Reference class="sailpoint.object.SPRight" name="ImpersonatePluginConfigurationRight"/>
        </RightRefs>
    </Capability>

</sailpoint>

