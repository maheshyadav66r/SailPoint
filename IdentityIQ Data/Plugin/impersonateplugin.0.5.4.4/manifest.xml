<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE Plugin PUBLIC "sailpoint.dtd" "sailpoint.dtd">
<Plugin name="impersonateplugin" displayName="Impersonate" disabled="false" version="0.5.4.4" minSystemVersion="7.3" certificationLevel="None" rightRequired=""><!-- ImpersonatePluginRight -->
