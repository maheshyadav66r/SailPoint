              <Field application="SalesForceApp" displayName="con_prov_policy_salesforce_direct_Locale" name="Question:7:LocaleSidKey" priority="10" required="true" reviewRequired="true" template="account" type="string" value="en_US"/>
              <Field application="SalesForceApp" displayName="con_prov_policy_salesforce_direct_LanguageLocaleKey" name="Question:8:LanguageLocaleKey" priority="10" required="true" reviewRequired="true" template="account" type="string" value="en_US"/>
