              <ReportColumnConfig field="eventname" header="Event" property="identity.name" sortable="true" width="146">
                <RenderScript>
                  <Source><![CDATA[
                   import sailpoint.object.*;
                    
                    Filter filter = Filter.and(Filter.eq("target", "Identity:"+value),Filter.eq("action", "identityLifecycleEvent"),Filter.eq("string1", "HR Source Lifecycle Event - Leaver"));

                    AuditEvent event = context.getUniqueObject(AuditEvent.class,filter);

                    String eventname = event!=null?event.getString1():"";
                    return eventname;
                  ]]></Source>
                </RenderScript>
              </ReportColumnConfig>
