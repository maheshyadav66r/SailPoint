<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE Workflow PUBLIC "sailpoint.dtd" "sailpoint.dtd">
<Workflow explicitTransitions="true" libraries="Identity" name="TestAccountManagement">
  <Variable name="inputForm"/>
  <Variable name="identityId"/>
  <Variable name="identityName"/>
  <Variable name="identityModel"/>
  <Variable name="launcher"/>
  <Variable name="confirmationForm"/>
  <Variable initializer="false" name="trace"/>
  <Step icon="Start" name="Start" posX="109" posY="91">
    <Transition to="initialze identityModel"/>
  </Step>
  <Step action="call:getIdentityModel" icon="Default" name="initialze identityModel" posX="299" posY="92" resultVariable="identityModel">
    <Script>
      <Source><![CDATA[
      log.error(" identityModel  without id or name of an identity  :  "+identityModel);
      ]]></Source>
    </Script>
    <Transition to="initializeInputForm"/>
  </Step>
  <Step icon="Default" name="initializeInputForm" posX="481" posY="93">
    <Approval mode="serial" name="Display Form" owner="ref:launcher" return="identityModel,workItemForm,confirmRequest,exitRequest" send="identityModel,launcher">
      <Arg name="workItemType" value="Form"/>
      <Arg name="workItemFormBasePath" value="identityModel"/>
      <Arg name="workItemForm" value="DB_operation_Selction_form"/>
    </Approval>
    <Script>
      <Source><![CDATA[
      log.error(" identityModel  after filling form   :  "+identityModel);
      ]]></Source>
    </Script>
    <Transition to="confirmation form"/>
  </Step>
  <Step action="call:buildReadOnlyForm" name="confirmation form" posX="588" resultVariable="confirmationForm">
    <Arg name="form" value="DB_operation_Selction_form"/>
    <Arg name="nextButtonLabel" value="label_confirm"/>
    <Transition to="review initializeInputForm"/>
  </Step>
  <Step icon="Default" name="review initializeInputForm" posX="690" posY="165">
    <Approval mode="serial" name="Display Form" owner="ref:launcher" renderer="lcmEditableWorkItemRenderer.xhtml" return="identityModel,workItemForm" send="identityModel,launcher,confirmationForm">
      <Arg name="workItemType" value="Form"/>
      <Arg name="workItemForm" value="ref:confirmationForm"/>
      <Arg name="form" value="DB_operation_Selction_form"/>
      <Arg name="workItemFormBasePath" value="identityModel"/>
      <Arg name="workItemDescription" value="Review Service Account Form"/>
    </Approval>
    <Transition to="Generic Step (2)"/>
  </Step>
  <Step icon="Default" name="Generic Step (2)" posX="806" posY="82">
    <Script>
      <Source><![CDATA[
        import sailpoint.object.*;
        import sailpoint.api.*;
        
        
        log.error("Generic Step 2 identityModel :  " + identityModel);

       /* for(int i=0;i<this.variables.length;i++){
        log.error(this.variables[i]);
        }*/
        
        log.error(" workflowcontext agrs   :  "+wfcontext.getArguments());
        log.error(" workflow variable  :  "+workflow.toXml());

      ]]></Source>
    </Script>
    <Transition to="Stop"/>
  </Step>
  <Step icon="Stop" name="Stop" posX="939" posY="87"/>
</Workflow>