<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE TaskDefinition PUBLIC "sailpoint.dtd" "sailpoint.dtd">
<TaskDefinition executor="sailpoint.reporting.LiveReportExecutor" name="Demo Report Identity Audit" progressMode="Percentage" resultAction="Rename" template="true" type="LiveReport">
  <Attributes>
    <Map>
      <entry key="report">
        <value>
          <LiveReport title="Demo Report Identity Audit">
            <DataSource objectType="sailpoint.object.Identity" type="Filter">
              <QueryParameters>
                <Parameter argument="application">
                  <QueryScript>
                    <Source><![CDATA[
                      import sailpoint.object.*;
                      import sailpoint.api.*;

                     // Application application=context.getObjectById(Application.class,value);
                      queryOptions.addFilter(Filter.eq("links.application.id",value));
                      return queryOptions;
                    ]]></Source>
                  </QueryScript>
                </Parameter>
                <Parameter argument="department" property="department">
                  <QueryScript>
                    <Source><![CDATA[
                      import sailpoint.object.*;
                      import sailpoint.api.*;

                      log.error("department--"+value);
                      queryOptions.addFilter(Filter.eq("department",value));

                      return queryOptions;
                    ]]></Source>
                  </QueryScript>
                </Parameter>
              </QueryParameters>
            </DataSource>
            <Columns>
              <ReportColumnConfig field="id" header="ID" property="id" width="110"/>
              <ReportColumnConfig field="name" header="Name" property="name" width="110"/>
              <ReportColumnConfig field="employee_id" header="EmployeeId" property="employeeId" width="110"/>
              <ReportColumnConfig field="department" header="Department" property="department" width="110"/>
              <ReportColumnConfig field="manager" header="Manager" property="manager.displayName" width="110"/>
              <ReportColumnConfig field="networkId" header="NetWorkId" property="networkId" width="110"/>
              <ReportColumnConfig field="email" header="Email" property="email" width="110"/>
            </Columns>
          </LiveReport>
        </value>
      </entry>
    </Map>
  </Attributes>
  <Description>Displays information about each role in detailed format.</Description>
  <Signature>
    <Inputs>
      <Argument name="application" type="Application">
        <Description>application link of the identity</Description>
      </Argument>
      <Argument name="department" type="String">
        <Description>department of the identity</Description>
      </Argument>
    </Inputs>
  </Signature>
</TaskDefinition>