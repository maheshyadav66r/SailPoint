<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE TaskDefinition PUBLIC "sailpoint.dtd" "sailpoint.dtd">
<TaskDefinition executor="sailpoint.reporting.LiveReportExecutor" name="Report-PasswordExpiryNotificationAEByHQL" progressMode="Percentage" resultAction="Rename" subType="Audit Report" template="true" type="LiveReport">
  <Attributes>
    <Map>
      <entry key="report">
        <value>
          <LiveReport title="AuditEventForPasswordExpirynotification">
            <DataSource type="Hql">
              <Query>
                FROM AuditEvent ae, Identity i
                WHERE ae.target = i.name
                AND i.type = 'employee'
                AND ae.action = 'Password Expiration Notification'
                </Query>
              <QueryParameters>
                <Parameter argument="fromDate">
                  <QueryScript>
                    <Source><![CDATA[

                      query=query+"AND ae.created BETWEEN :fromDate AND :toDate";

                      log.error("event value--"+query);
                      return query;
                    ]]></Source>
                  </QueryScript>
                </Parameter>
              </QueryParameters>
            </DataSource>
            <Columns>
              <ReportColumnConfig field="userName" header="UserName" property="target" width="110"/>
              <ReportColumnConfig field="email" header="Email" property="attributeValue" width="110"/>
              <ReportColumnConfig field="notificationDate" header="NotificationDate" property="created" width="110"/>
              <ReportColumnConfig field="expiryDate" header="ExpiryDate" property="attributes.Expires On" width="110"/>
              <ReportColumnConfig field="interval" header="Interval" property="attributes.Interval" width="110"/>
            </Columns>
          </LiveReport>
        </value>
      </entry>
    </Map>
  </Attributes>
  <Signature>
    <Inputs>
      <Argument name="fromDate" required="true" type="date">
        <Description>select dates (from) on which selected event triggered </Description>
      </Argument>
      <Argument name="toDate" required="true" type="date">
        <Description>select dates (to) on which selected event triggered </Description>
      </Argument>
    </Inputs>
  </Signature>
</TaskDefinition>