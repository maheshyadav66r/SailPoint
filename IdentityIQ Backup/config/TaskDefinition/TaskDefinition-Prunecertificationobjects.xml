<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE TaskDefinition PUBLIC "sailpoint.dtd" "sailpoint.dtd">
<TaskDefinition formPath="/monitor/tasks/FullRuleRunInput.xhtml" name="PruneCertificationObjects" resultAction="Delete" subType="task_item_type_generic" type="Generic">
  <Attributes>
    <Map>
      <entry key="TaskSchedule.host"/>
      <entry key="certificationObject" value="Certification Entity"/>
      <entry key="limit" value="5"/>
      <entry key="ruleName" value="ABMB AfterProvisioningRule"/>
      <entry key="taskCompletionEmailNotify" value="Disabled"/>
      <entry key="taskCompletionEmailRecipients"/>
      <entry key="taskCompletionEmailTemplate"/>
    </Map>
  </Attributes>
  <Description>A task that can be used to run an arbitrary rule.</Description>
  <Owner>
    <Reference class="sailpoint.object.Identity" name="spadmin"/>
  </Owner>
  <Parent>
    <Reference class="sailpoint.object.TaskDefinition" name="Run Rule"/>
  </Parent>
  <Signature>
    <Inputs>
      <Argument name="ruleName" required="true" type="Rule">
        <Prompt> Rule </Prompt>
      </Argument>
      <Argument name="certificationObject" required="true" type="string">
        <Description>select CertificationObject</Description>
      </Argument>
      <Argument name="limit" required="true" type="int">
        <Description>Select No Of Objects</Description>
      </Argument>
    </Inputs>
    <Returns>
      <Argument name="ObjectType" type="string"/>
      <Argument name="Object Count Before Pruning" type="int"/>
      <Argument name="Object Count After Pruning" type="int"/>
    </Returns>
  </Signature>
</TaskDefinition>