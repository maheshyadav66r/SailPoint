<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE PasswordPolicy PUBLIC "sailpoint.dtd" "sailpoint.dtd">
<PasswordPolicy description="" name="PasswordForADAccount">
  <PasswordConstraints>
    <Map>
      <entry key="checkCaseSensitive">
        <value>
          <Boolean/>
        </value>
      </entry>
      <entry key="checkPasswordAgainstAccountID">
        <value>
          <Boolean/>
        </value>
      </entry>
      <entry key="checkPasswordAgainstDisplayName">
        <value>
          <Boolean/>
        </value>
      </entry>
      <entry key="checkPasswordTriviality">
        <value>
          <Boolean>true</Boolean>
        </value>
      </entry>
      <entry key="checkPasswordsAgainstAccountAttributes">
        <value>
          <Boolean/>
        </value>
      </entry>
      <entry key="checkPasswordsAgainstDictionary">
        <value>
          <Boolean/>
        </value>
      </entry>
      <entry key="checkPasswordsAgainstIdentityAttributes">
        <value>
          <Boolean/>
        </value>
      </entry>
      <entry key="minAccountIDUniqueChars" value="16"/>
      <entry key="minDisplayNameUniqueChars" value="8"/>
      <entry key="minHistoryUniqueChars"/>
      <entry key="passwordHistory" value="2"/>
      <entry key="passwordMaxLength" value="16"/>
      <entry key="passwordMinAlpha" value="1"/>
      <entry key="passwordMinCharType"/>
      <entry key="passwordMinLength" value="8"/>
      <entry key="passwordMinLower"/>
      <entry key="passwordMinNumeric" value="1"/>
      <entry key="passwordMinSpecial" value="[A-Za-z0-9@#/*]+"/>
      <entry key="passwordMinUpper" value="1"/>
      <entry key="passwordRepeatedChar"/>
    </Map>
  </PasswordConstraints>
</PasswordPolicy>