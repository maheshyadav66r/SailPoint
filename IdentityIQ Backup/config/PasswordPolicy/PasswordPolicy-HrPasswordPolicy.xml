<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE PasswordPolicy PUBLIC "sailpoint.dtd" "sailpoint.dtd">
<PasswordPolicy description="To create passwords for the accounts created from the HR Source" name="HR Password Policy">
  <PasswordConstraints>
    <Map>
      <entry key="checkCaseSensitive">
        <value>
          <Boolean/>
        </value>
      </entry>
      <entry key="checkPasswordAgainstAccountID">
        <value>
          <Boolean/>
        </value>
      </entry>
      <entry key="checkPasswordAgainstDisplayName">
        <value>
          <Boolean>true</Boolean>
        </value>
      </entry>
      <entry key="checkPasswordTriviality">
        <value>
          <Boolean/>
        </value>
      </entry>
      <entry key="checkPasswordsAgainstAccountAttributes">
        <value>
          <Boolean/>
        </value>
      </entry>
      <entry key="checkPasswordsAgainstDictionary">
        <value>
          <Boolean/>
        </value>
      </entry>
      <entry key="checkPasswordsAgainstIdentityAttributes">
        <value>
          <Boolean>true</Boolean>
        </value>
      </entry>
      <entry key="minAccountIDUniqueChars" value="10"/>
      <entry key="minDisplayNameUniqueChars"/>
      <entry key="minHistoryUniqueChars"/>
      <entry key="passwordHistory"/>
      <entry key="passwordMaxLength"/>
      <entry key="passwordMinAlpha"/>
      <entry key="passwordMinCharType"/>
      <entry key="passwordMinLength"/>
      <entry key="passwordMinLower" value="2"/>
      <entry key="passwordMinNumeric" value="3"/>
      <entry key="passwordMinSpecial" value="2"/>
      <entry key="passwordMinUpper" value="2"/>
      <entry key="passwordRepeatedChar" value="2"/>
    </Map>
  </PasswordConstraints>
</PasswordPolicy>