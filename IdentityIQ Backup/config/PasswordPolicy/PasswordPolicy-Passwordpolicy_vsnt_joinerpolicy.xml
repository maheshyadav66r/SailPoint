<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE PasswordPolicy PUBLIC "sailpoint.dtd" "sailpoint.dtd">
<PasswordPolicy description="Used for new users" name="PasswordPolicy_VSNT_JoinerPolicy">
  <PasswordConstraints>
    <Map>
      <entry key="checCaseSensitive">
        <value>
          <Boolean/>
        </value>
      </entry>
      <entry key="checkPasswordAgainstAccountID">
        <value>
          <Boolean/>
        </value>
      </entry>
      <entry key="checkPasswordAgainstDisplayName">
        <value>
          <Boolean/>
        </value>
      </entry>
      <entry key="checkPasswordTriviality">
        <value>
          <Boolean/>
        </value>
      </entry>
      <entry key="checkPasswordsAgainstAccountAttributes">
        <value>
          <Boolean/>
        </value>
      </entry>
      <entry key="checkPasswordsAgainstDictionary">
        <value>
          <Boolean/>
        </value>
      </entry>
      <entry key="checkPasswordsAgainstIdentityAttributes">
        <value>
          <Boolean/>
        </value>
      </entry>
      <entry key="minAccountIDUniqueChars"/>
      <entry key="minDisplayNameUniqueChars"/>
      <entry key="minHistoryUniqueChars"/>
      <entry key="passwordHistory"/>
      <entry key="passwordMaxLength" value="15"/>
      <entry key="passwordMinAlpha"/>
      <entry key="passwordMinCharType"/>
      <entry key="passwordMinLength" value="8"/>
      <entry key="passwordMinLower" value="8"/>
      <entry key="passwordMinNumeric" value="2"/>
      <entry key="passwordMinSpecial" value="0"/>
      <entry key="passwordMinUpper" value="1"/>
      <entry key="passwordRepeatedChar"/>
      <entry key="passwordSpecialCharacters"/>
    </Map>
  </PasswordConstraints>
</PasswordPolicy>