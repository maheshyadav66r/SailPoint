<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE IdentityTrigger PUBLIC "sailpoint.dtd" "sailpoint.dtd">
<IdentityTrigger disabled="true" handler="sailpoint.api.WorkflowTriggerHandler" name="NativeChangeEvent" type="NativeChange">
  <Owner>
    <Reference class="sailpoint.object.Identity" name="spadmin"/>
  </Owner>
  <HandlerParameters>
    <Attributes>
      <Map>
        <entry key="businessProcess"/>
        <entry key="identityProcessingThreshold"/>
        <entry key="identityProcessingThresholdType"/>
        <entry key="workflow" value="Lifecycle Event - Manager Approval for all native changes"/>
      </Map>
    </Attributes>
  </HandlerParameters>
</IdentityTrigger>