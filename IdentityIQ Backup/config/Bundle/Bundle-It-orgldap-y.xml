  <Profiles>
    <Profile>
      <ApplicationRef>
        <Reference class="sailpoint.object.Application" name="IntConApplication"/>
      </ApplicationRef>
      <Constraints>
        <Filter operation="EQ" property="atldapUser" value="Y"/>
