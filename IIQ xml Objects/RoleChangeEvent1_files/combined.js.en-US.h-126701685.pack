Ext.onReady(function(){if(typeof(buildTooltips)!="undefined")
buildTooltips();function disablePrototypeJS(method,pluginsToDisable){var handler=function(event){event.target[method]=undefined;};pluginsToDisable.forEach(function(plugin){jQuery(window).on(method+'.bs.'+plugin,handler);});}
var pluginsToDisable=['collapse','dropdown','modal','tooltip','popover'];disablePrototypeJS('show',pluginsToDisable);disablePrototypeJS('hide',pluginsToDisable);jQuery(document).on('shown.bs.dropdown',function(event){var dropdown=jQuery(event.target);dropdown.find('.dropdown-menu').attr('aria-expanded',true);});jQuery(document).on('hidden.bs.dropdown',function(event){var dropdown=jQuery(event.target);dropdown.find('.dropdown-menu').attr('aria-expanded',false);});jQuery('a.menuitem').keydown(function(e){if(e.keyCode===32){this.click();e.stopPropagation();return false;}});});