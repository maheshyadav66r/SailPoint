return ImageRadio.getRadioValue(radio);return null;},updateRadios:function(){var radios=this._getRadios();Ext.each(radios,function(radio,idx){if((null!=radio.name)&&(0==radio.name.indexOf(this.radioNamePrefix))){ImageRadio.attachEventsToRadio(radio);if(this._isSelected(radio)){ImageRadio.selectRadio(radio);}}},this);},getChangedValues:function(){if(null==this.radioNamePrefix){return this.changedValues;}
