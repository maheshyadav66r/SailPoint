else if(null!=suggestElt){suggestElt.disabled=disabled;selectBox.disabled=disabled;addBtn.disabled=disabled;deleteBtn.disabled=disabled;}
else{throw'Could not find multiselect or suggest elements to disable.';}}
function hashToMapString(hash){var mapString="{";var sep="";Ext.Object.each(hash,function(key,val){mapString+=sep+key+"="+val;sep=",";});mapString+="}";return mapString;}
function arrayToMapString(myArray){var mapString="{";var sep="";for(var key in myArray){if(key!="extend"){mapString+=sep+key+"="+myArray[key];sep=", ";}}
mapString+="}";return mapString;}
function arrayToString(myArray,includeBrackets,noSpaces){var s='';if(null!=myArray){if(typeof myArray=='string'){s=myArray;}else{var sep='';for(var i=0;i<myArray.length;i++){s+=sep+myArray[i];if(noSpaces){sep=',';}else{sep=', ';}}}}
if(includeBrackets){s='['+s+']';}
return s;}
function stringToArray(myString,includeBrackets){if(myString==null)
return[];var str=myString;if(includeBrackets){str=myString.substring(1,myString.length-1)}
return str.split(', ');}
function countSelected(container,checkboxIds,displayPanel)
{var count=0;if(null!=container)
{var checks=container.getElementsByTagName('input');var checkboxes=Ext.Array.toArray(checks);for(var i=0;i<checkboxes.length;i++)
{if(checkboxIds){if(checkboxes[i].checked&&checkboxes[i].id==checkboxIds)
count+=1;}else{if(checkboxes[i].checked)
count+=1;}}
if(displayPanel)
{var tpl=new Ext.Template("{0} identity(s) selected");displayPanel.innerHTML="<span class='buttonStyle'>"+tpl.apply([count])+" </span>";Ext.fly(displayPanel).slideIn();}}
return count;}
function toggleSelectAll(container,selectAllCheckbox,checkboxIds)
{var isChecked=selectAllCheckbox.checked;var checks=container.getElementsByTagName('input');var checkboxes=Ext.Array.toArray(checks);for(var i=0;i<checkboxes.length;i++)
{if(checkboxes[i].id==checkboxIds)
checkboxes[i].checked=isChecked;}}
function getElementsByClassAndSuffix(className,idSuffix){var eltByClassArray=document.getElementsByClassName(className);var resultArray=[];Ext.each(eltByClassArray,function(element){if((element.id.indexOf(idSuffix)+idSuffix.length)===element.id.length){resultArray.push(element);}});return resultArray;}
function getSelectedRadioInput(inputID){var radioInputs=Ext.getDom(document.getElementsByName(inputID));var selectedInput;for(var i=0;i<radioInputs.length&&!selectedInput;++i){var inputElement=radioInputs.item(i);if(inputElement.checked){selectedInput=inputElement.value;}}
return selectedInput;}
function endsWith(string,substring){var lastIndex=string.lastIndexOf(substring);return(lastIndex+substring.length==string.length);}
function beginsWith(string,substring){return string.indexOf(substring)==0;}
function isNumber(potentialNumber){if(potentialNumber<=0||potentialNumber>0){return true;}else{return false;}}
function confirmSave(isPageDirty,actionButtonId){confirmSaveCancel("Save System Settings","Are you sure you want to save your changes?",isPageDirty,actionButtonId);}
function confirmCancel(isPageDirty,actionButtonId){confirmSaveCancel("Cancel","Are you sure you want to cancel?  All changes will be lost.",isPageDirty,actionButtonId);}
function confirmSaveCancel(title,msg,isPageDirty,actionButtonId){if(isPageDirty&&(isPageDirty===true||isPageDirty==='true')){Ext.MessageBox.confirm(title,msg,function(button){if(button=='yes'){return Ext.getDom(actionButtonId).click();}});}else{return Ext.getDom(actionButtonId).click();}}
