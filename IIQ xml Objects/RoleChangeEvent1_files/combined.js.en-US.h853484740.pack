function viewAccountGroup(appName,groupAttr,group,id,refererType,refererId,parentId,certificationItemId){var params;if(id){if(group){params={id:id,groupName:group};}else{params={id:id};}}else{params={applicationName:appName,groupAttribute:groupAttr,groupName:group,certificationItemId:certificationItemId,'editForm:id':null};}
