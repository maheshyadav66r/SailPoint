return isHandled;}
function handleTabKey(event){var isHandled=false,items=getVisibleLinks(),index=items.index(event.target);if(!event.shiftKey&&index===items.length-1){jQuery('.quicklink-button').parent().next().children('a').focus();isHandled=true;}
