body, div, dl, dt, dd, ul, ol, li, h1, h2, h3, h4, h5, h6, pre, form, fieldset, input, textarea, p, blockquote {margin: 0;padding: 0;}table {border-collapse: collapse;border-spacing: 0;}fieldset, img {border: 0;}address, caption, cite, code, dfn, th, var {font-style: normal;font-weight: normal;}ol, ul {list-style: none;}caption, th {text-align: left;}h1, h2, h3, h4, h5, h6 {font-size: 100%;font-weight: normal;}q:before, q:after {content: '';}abbr, acronym {border: 0;}.font10,.font10 td,.font10 select,.font10 input,.font10 a {font-size: 12px;line-height: normal;}input.font10 {line-height: normal;}.handle {cursor: move;}.pointer {cursor: pointer;}.textBold {font-weight: bold;}.center {text-align: center;}.italic {font-style: italic;}.width50 {width: 45%;}.width100 {width: 100%;}.inputWidth {width: 200px;}.inputNumberWidth {width: 40px;}.customWidth {width: 94%;}.dashWidth100 {width: 100%;}.inlineTable {display: inline-table}.padded {padding: 3px;}.padded10 {padding: 10px;}.padDown {padding-bottom: 10px;}.padRight15 {padding-right: 15px;}.marDown {margin-bottom: 10px;}.marUp {margin-top: 10px;}.paddedTbl td, .paddedTbl th {padding: 4px;}.paddedTbl2 td, .paddedTbl2 th {padding: 5px !important;}.nonPaddedTbl td {padding: 0;}.nonPaddedTbl th {padding: 4px;}.horizPaddedTbl td, .horizPaddedTbl th {padding-left: 4px;padding-right: 4px;}.lightBorder {border: 1px #ccc solid;}.disabled {color: #999;}.green,.label.green {color: seagreen;}.red,.label.red {color: tomato;}.floatLeft {float: left;}.normal {white-space: normal;}.top {vertical-align: top;}.rBorder {border-right: 1px #ccc solid;}.lrBorder {border-right: 1px #ccc solid;border-left: 1px #ccc solid;}.vis-clear {clear: both;font-size: 0;height: 0;line-height: 0;width: 100%;}.zerobottom {margin-bottom: 0 !important;padding-bottom: 0 !important;}.discoverDomainSpinner {display : none;position: fixed;z-index: 999;height: 100%;width: 100%;top: 0;left: 0;filter: alpha(opacity=60);opacity: 1;-moz-opacity: 0.8;}.discoverDomainSpinner img{background :white none repeat scroll 0 0;color : black;position: fixed;height: 21px;width: 35px;top: 60%;left: 48%;}.applicationExtTabs .ADLdapTabPanel .x-tab-bar-body {border-right: none !important;}* {font-family: "Open Sans", "Helvetica Neue", Helvetica, Arial, sans-serif;}a, a:link {text-decoration: none;color: #2ba4c7;}a:visited, a:active {text-decoration: none;color: #0580a4;}a:hover {color: #0580a4;text-decoration: none;}a.disclosure {background: url(../images/icons/TealArrowDownWhtSdw.png) center right no-repeat;padding-right: 26px;cursor: pointer;}a.disclosureUp {background: url(../images/icons/TealArrowUpWhtSdw.png) center right no-repeat !important;}a.action {background: url(../images/icons/general_action_link_10.png) center left no-repeat;color: #bf8b28;padding-left: 12px;font-weight: bold;cursor: pointer;}body {margin: 0 auto;font-family: Arial, sans-serif;font-size: 12px;line-height: 16px;background-color: #037DA1;color: #FFFFFF;height: 100%;}body.x-masked-relative {height: auto;}fieldset, .fieldset {padding: 1em;background-color: #EEEEEE;margin-top: 5px;}html {height: 100%}h2 {font-size: 15px;font-weight: bold;color: #037da1;}input::-ms-clear {display: none;}legend, .form-renderer legend {background-color: #F9F9F9;border: 1px solid gray;font-weight: bold;}.form-renderer legend {width: auto;margin-bottom: 0;font-weight: normal;}.form-renderer label {max-width: none;}.x-webkit legend {border-top: 2px solid gray;}textarea {font-family: Arial, sans-serif;font-size: 13px;border: 1px #b5b8c8 solid;}input {margin: auto;padding-top: 1px !important;padding-bottom: 1px !important;}select {font-size: 13px;}thead th {padding: 3px;}ol {list-style: decimal;}ol li {list-style: decimal;margin-left: 25px;}ul {list-style: disc;}ul li {list-style: disc;margin-left: 25px;}td.x-form-invalid-under ul li {list-style: none;}strong, b {font-weight: bold !important;}em, i {font-style: italic;}em button {font-style: normal !important;}em a span {font-style: normal !important;}select {font-family: "Arial Unicode MS", sans-serif}.spContent {border-radius: 2px; -moz-border-radius: 2px; -webkit-border-radius: 2px; }#bodyDivFooter {border-radius: 3px; -moz-border-radius: 3px; -webkit-border-radius: 3px; border: 1px solid #CCCCCC;}.gridLegend {padding:2px;border-radius: 5px 5px 0px 0px; -moz-border-radius: 5px 5px 0px 0px; -webkit-border-radius: 5px 5px 0px 0px; border: 1px solid #C1DADF;}.spTabledAjaxContent,.spLightBlueTabledContent,.spLightGreenTabledContent,.spBlueTabledContent,.spYellowTabledContent,.roundedEdit,.spAjaxLightBlueTabledContent,.spAjaxLightGreenTabledContent,.spAjaxBlueTabledContent,#searchResultsContent,#searchResultsOptionsContent {border-radius: 2px; -moz-border-radius: 2px; -webkit-border-radius: 2px; border: 1px solid #ccc;}.roundedInnerEdit {border-radius: 5px; -moz-border-radius: 5px; -webkit-border-radius: 5px; border: 1px solid #BBBBBB;}.detailsDiv,.detailsWarnDiv,.detailsCritDiv {border-radius: 2px; -moz-border-radius: 2px; -webkit-border-radius: 2px; border: 1px solid #ccc;}.wrappingGrid .x-grid-cell-inner,.wrappingGrid .x-grid-hd-inner {white-space: normal !important;line-height: 18px;}.wrappingGridCells .x-grid-cell-inner {white-space: normal;line-height: 18px;}.wrappingGridCellsOW .x-grid-cell-inner {white-space: normal;line-height: 18px;}.noWrap .x-grid-cell-inner {white-space: nowrap;}.wrappingGridCells .hidden-cell .x-grid-cell-inner,.wrappingGridCellsOW .hidden-cell .x-grid-cell-inner,.noWrap .hidden-cell .x-grid-cell-inner{white-space: nowrap;}.gridSelectPage {background-image: url(../images/icons/table.png) !important;}.gridSelectAll {background-image: url(../images/icons/table_multiple.png) !important;}.gridDeselectPage {background-image: url(../images/icons/table_delete.png) !important;}.gridDeselectAll {background-image: url(../images/icons/table_multiple_delete.png) !important;}.searchPanel {background-color: #EEEEEE !important;border: 1px solid #CCCCCC !important;padding: 10px 5px 0px 10px;}.searchPanel > .x-panel-body {background-color: transparent !important;border-width: 0px;}.searchPanelForm {padding: 0px 5px 0px 5px;}.searchPanelToolbar {margin-top: 0px !important;padding-top: 6px !important;padding-bottom: 6px !important;padding-right: 0px !important;}.toolbarRightBtn {margin-right: 0px !important;}.searchPanelField > .x-panel-body {background-color: transparent !important;}.x-form-multiselect-body .x-boundlist .x-mask {background: none;}.x-form-itemselector-body .x-form-item {margin: 0;}.x-form-itemselector-top {background-image: url(../images/extjs-ux/top2.gif);}.x-form-itemselector-up {background-image: url(../images/extjs-ux/up2.gif);}.x-form-itemselector-add {background-image: url(../images/extjs-ux/right2.gif);}.x-form-itemselector-remove {background-image: url(../images/extjs-ux/left2.gif);}.x-form-itemselector-down {background-image: url(../images/extjs-ux/down2.gif);}.x-form-itemselector-bottom {background-image: url(../images/extjs-ux/bottom2.gif);}.multitext-trigger {background-image: url(../images/icons/addPlusBlk.png) !important;}.spradio table tr td label {padding-right: 15px;}.esig-errors > .x-panel-body {color: #FF0000 !important;font-size: 12px !important;}.eSigToolTipTitle {background-color: #EEEEEE;}.eSigTipSpan {background-image: url(../images/icons/esigned-16px.png) !important;background-repeat: no-repeat;background-position: right;padding-right: 20px;}.eSigToolTip td {vertical-align: top;}.eSigToolTip td:first-child {font-weight: bold;padding-right: 8px;}.x-grid-cell-checkcolumn .x-grid-cell-inner {padding-top: 4px;padding-bottom: 2px;line-height: 14px;}.x-grid-with-row-lines .x-grid-cell-checkcolumn .x-grid-cell-inner {padding-top: 3px;}.x-grid-checkheader {height: 14px;background-image: url('../images/unchecked.gif');background-position: 50% -2px;background-repeat: no-repeat;background-color: transparent;}.x-grid-checkheader-checked {background-image: url('../images/checked.gif');}.x-grid-checkheader-editor .x-form-cb-wrap {text-align: center;}.ui-button {margin-right: unset;padding: unset;white-space: pre;}.ui-button.ui-button-text-only .ui-button-text {padding: unset;line-height: unset;}.ui-button.ui-button-icon-only .ui-icon {left: unset;top: unset;}